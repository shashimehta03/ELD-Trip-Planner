# ---- Django ----
# Generate a real key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,.onrender.com

# ---- CORS / CSRF ----
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=https://*.vercel.app,https://*.onrender.com

# ---- MongoDB ----
# Trips are stored in MongoDB. If the URI is blank OR the server is unreachable,
# the app transparently falls back to the local SQLite ORM so it still runs.
#   Local:  mongodb://localhost:27017
#   Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=eld_trip_planner
MONGODB_COLLECTION=trips
